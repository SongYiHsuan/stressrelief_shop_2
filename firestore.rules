rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function adminPath() {
      return /databases/$(database)/documents/admins/$(request.auth.uid);
    }

    function adminExists() {
      return signedIn() && exists(adminPath());
    }

    function adminData() {
      return get(adminPath()).data;
    }

    function isActiveAdmin() {
      return adminExists()
        && adminData().active == true
        && (
          adminData().role == 'admin'
          || adminData().role == 'owner'
        );
    }

    function immutableMemberFieldsUnchanged(documentId) {
      return request.resource.data.memberId
          == resource.data.memberId

        && request.resource.data.lineUserId
          == resource.data.lineUserId

        && request.resource.data.barcodeValue
          == resource.data.barcodeValue

        && (
          !resource.data.keys().hasAny(['lineUserId'])
          || request.resource.data.lineUserId == documentId
        );
    }

    /*
     * 管理員帳號
     */
    match /admins/{adminUid} {
      allow read: if isActiveAdmin();

      /*
       * 不允許從瀏覽器自行提升管理員權限。
       */
      allow create, update, delete: if false;
    }

    /*
     * 會員主資料
     */
    match /members/{memberDocumentId} {
      allow read: if isActiveAdmin();

      allow create: if isActiveAdmin()
        && request.resource.data.memberId is string
        && request.resource.data.memberId.size() > 0
        && (
          !request.resource.data.keys().hasAny(['lineUserId'])
          || request.resource.data.lineUserId == memberDocumentId
        );

      allow update: if isActiveAdmin()
        && immutableMemberFieldsUnchanged(memberDocumentId);

      allow delete: if false;
    }

    /*
     * 儲值金紀錄：
     * 可以新增，不允許竄改既有歷史紀錄。
     */
    match /walletLogs/{logId} {
      allow read: if isActiveAdmin();

      allow create: if isActiveAdmin()
        && request.resource.data.operatorUid
          == request.auth.uid
        && request.resource.data.memberId is string;

      allow update, delete: if false;
    }

    /*
     * 點數紀錄
     */
    match /pointLogs/{logId} {
      allow read: if isActiveAdmin();

      allow create: if isActiveAdmin()
        && request.resource.data.operatorUid
          == request.auth.uid
        && request.resource.data.memberId is string;

      allow update, delete: if false;
    }

    /*
     * 會員資料修改紀錄
     */
    match /memberEditLogs/{logId} {
      allow read: if isActiveAdmin();

      allow create: if isActiveAdmin()
        && request.resource.data.operatorUid
          == request.auth.uid
        && request.resource.data.memberId is string;

      allow update, delete: if false;
    }

    /*
     * 優惠券
     */
    match /coupons/{couponId} {
      allow read, create, update: if isActiveAdmin();
      allow delete: if false;
    }

    match /memberCoupons/{memberCouponId} {
      allow read, create, update: if isActiveAdmin();
      allow delete: if false;
    }

    /*
     * 發送紀錄
     */
    match /broadcastLogs/{broadcastId} {
      allow read, create, update: if isActiveAdmin();
      allow delete: if false;
    }

    match /broadcastTargets/{targetId} {
      allow read, create, update: if isActiveAdmin();
      allow delete: if false;
    }

    /*
     * 活動資料
     */
    match /activities/{activityId} {
      allow read, create, update: if isActiveAdmin();
      allow delete: if false;
    }

    /*
     * 其他未明確允許的資料全部拒絕。
     */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
